					Creation of a Scanner

Step 1: Go to the scanner folder

Create CMakeLists.txt in scanner/ folder (if not already):

vi CMakeLists.txt

Paste:

cmake_minimum_required(VERSION 3.5)

include($ENV{IDF_PATH}/tools/cmake/project.cmake)
project(scanner)

step 2: Go to the scanner folder

cd ~/esp32_projects/ble_tracking/scanner
mkdir -p main
cd main

Step 3: Create and edit main.c with vi

vi main.c

Inside vi, press i to enter insert mode, then paste the following code:

#include "esp_gap_ble_api.h"
#include "esp_log.h"
#include "nvs_flash.h"
#include "esp_bt.h"
#include "esp_bt_main.h"
#include <string.h>
#include <math.h>

static const char *TAG = "BLE_SCANNER";

const char *beacons[] = {"beacon1", "beacon2"};
#define NUM_BEACONS 2

float calculate_distance(int rssi)
{
    int txPower = -59;   // RSSI value at 1 meter
    float n = 2.0;       // signal propagation constant

    float distance = pow(10.0, ((float)(txPower - rssi) / (10 * n)));

    return distance;
}

static void gap_cb(esp_gap_ble_cb_event_t event, esp_ble_gap_cb_param_t *param)
{
    switch(event)
    {
        case ESP_GAP_BLE_SCAN_PARAM_SET_COMPLETE_EVT:
            esp_ble_gap_start_scanning(0);   // start continuous scanning
            break;

        case ESP_GAP_BLE_SCAN_RESULT_EVT:
        {
            esp_ble_gap_cb_param_t *scan_result = param;

            char name[32] = {0};
            uint8_t name_len = 0;

            uint8_t *adv_name = esp_ble_resolve_adv_data(
                scan_result->scan_rst.ble_adv,
                ESP_BLE_AD_TYPE_NAME_CMPL,
                &name_len);

            if (adv_name && name_len > 0)
            {
                memcpy(name, adv_name, name_len);
                name[name_len] = '\0';

                for (int i = 0; i < NUM_BEACONS; i++)
                {
                    if (strcmp(name, beacons[i]) == 0)
                    {
                        int rssi = scan_result->scan_rst.rssi;
                        float distance = calculate_distance(rssi);

                        ESP_LOGI(TAG,
                                 "Detected %s RSSI:%d Distance: %.2f meters",
                                 name,
                                 rssi,
                                 distance);
                    }
		}
            }

            break;
        }

        default:
            break;
    }
}
static esp_ble_scan_params_t ble_scan_params = {
    .scan_type = BLE_SCAN_TYPE_ACTIVE,
    .own_addr_type = BLE_ADDR_TYPE_PUBLIC,
    .scan_filter_policy = BLE_SCAN_FILTER_ALLOW_ALL,
    .scan_interval = 0x50,
    .scan_window = 0x30,
    .scan_duplicate = BLE_SCAN_DUPLICATE_DISABLE
};
void app_main(void)
{
    esp_err_t ret = nvs_flash_init();

    if (ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND)
    {
        ESP_ERROR_CHECK(nvs_flash_erase());
        ret = nvs_flash_init();
    }

    ESP_ERROR_CHECK(ret);

    ESP_ERROR_CHECK(esp_bt_controller_mem_release(ESP_BT_MODE_CLASSIC_BT));

    esp_bt_controller_config_t bt_cfg = BT_CONTROLLER_INIT_CONFIG_DEFAULT();

    ESP_ERROR_CHECK(esp_bt_controller_init(&bt_cfg));
    ESP_ERROR_CHECK(esp_bt_controller_enable(ESP_BT_MODE_BLE));
    ESP_ERROR_CHECK(esp_bluedroid_init());
    ESP_ERROR_CHECK(esp_bluedroid_enable());

    ESP_ERROR_CHECK(esp_ble_gap_register_callback(gap_cb));

    ESP_ERROR_CHECK(esp_ble_gap_set_scan_params(&ble_scan_params));

    ESP_LOGI(TAG, "BLE Scanner Started");
}


